# Anthropic API key — get yours at https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Telegram Bot — create via @BotFather in Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather

# Telegram Chat ID — message your bot, then visit:
# https://api.telegram.org/bot<TOKEN>/getUpdates → find "chat":{"id": NNNN}
TELEGRAM_CHAT_ID=your-chat-id-here
